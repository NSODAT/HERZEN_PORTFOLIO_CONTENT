@startuml VKR_Activity_NightResolve
!theme plain
start

:Собрать ночные цели:\nмафия, доктор, маньяк,\nлюбовница, комиссар;

if (Доктор лечит цель мафии?) then (да)
  :Жертва мафии спасена;
else (нет)
  :Зафиксировать убийство мафии;
endif

if (Доктор лечит цель маньяка?) then (да)
  :Жертва маньяка спасена;
else (нет)
  :Зафиксировать убийство маньяка;
endif

:Применить правило пары\nлюбовницы (оба при смерти одного);

:Сформировать список смертей;

:Комиссар: запись результата\nпроверки (мафия/мирный);

if (check_win(alive)?) then (mafia / peaceful / maniac)
  :Игра окончена,\nзаписать winner;
  stop
else (продолжение)
  :phase := day,\nувеличить day_number;
  :Обновить Redis;\nуведомить подписчиков\nWebSocket (Mini App);
endif

stop

@enduml
